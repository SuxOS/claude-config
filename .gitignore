# This repo tracks ONLY hand-authored Claude config under home/.claude/.
# Everything else in a live ~/.claude is machine state — never commit it.
*.bak-*
*.bak
.DS_Store

# Python bytecode from the tracked hooks / CI linter (run locally or in CI).
__pycache__/
*.pyc

# skill-creator eval scratch
home/.claude/skills/*-workspace/

# Claude Code drops isolated worktrees (a nested .git repo) under the repo root.
# .git/info/exclude is per-clone and doesn't travel with the repo, so exclude it
# here too — otherwise a stray `git add -A` on a fresh clone commits the nested repo.
/.claude/worktrees/
