{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Bash(gh repo *)",
      "Bash(gh search *)",
      "Bash(npx wrangler *)",
      "Bash(npm *)",
      "Bash(python3 *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(node *)",
      "WebFetch",
      "WebSearch",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(scp *)",
      "Bash(tar *)",
      "Bash(gh secret *)",
      "Bash(gh auth *)",
      "Bash(gh repo delete *)",
      "Bash(gh repo edit *)",
      "Bash(gh repo transfer *)",
      "Bash(gh api -X *)",
      "Bash(gh api --method *)",
      "Bash(npx wrangler deploy)",
      "Bash(npx wrangler deploy *)",
      "Bash(npx wrangler delete)",
      "Bash(npx wrangler delete *)",
      "Bash(npx wrangler secret *)",
      "Bash(npx wrangler kv namespace delete *)",
      "Bash(npx wrangler kv:namespace delete *)",
      "Bash(npx wrangler kv key delete *)",
      "Bash(npx wrangler kv:key delete *)",
      "Bash(npx wrangler r2 bucket delete *)",
      "Bash(npx wrangler r2 object delete *)",
      "Bash(npx wrangler d1 delete *)",
      "Bash(*wrangler deploy)",
      "Bash(*wrangler deploy *)",
      "Bash(*wrangler * deploy)",
      "Bash(*wrangler * deploy *)",
      "Bash(*wrangler pages publish *)",
      "Bash(*wrangler delete)",
      "Bash(*wrangler delete *)",
      "Bash(*wrangler secret *)",
      "Bash(wrangler d1 execute *)",
      "Bash(*wrangler d1 execute *)",
      "Bash(*wrangler d1 delete *)",
      "Bash(*wrangler kv * delete *)",
      "Bash(*wrangler r2 bucket delete *)",
      "Bash(*wrangler r2 object delete *)",
      "Bash(*wrangler queues delete *)",
      "Bash(*wrangler pages * delete *)",
      "Bash(*wrangler vectorize delete *)",
      "Bash(*wrangler pipelines delete *)",
      "Bash(*wrangler * delete *)",
      "Bash(*wrangler d1 create *)",
      "Bash(*wrangler kv namespace create *)",
      "Bash(*wrangler kv:namespace create *)",
      "Bash(*wrangler r2 bucket create *)",
      "Bash(*wrangler hyperdrive create *)",
      "Bash(*wrangler hyperdrive update *)",
      "mcp__plugin_cloudflare_cloudflare-bindings__r2_bucket_delete",
      "mcp__plugin_cloudflare_cloudflare-bindings__kv_namespace_delete",
      "mcp__plugin_cloudflare_cloudflare-bindings__d1_database_delete",
      "mcp__plugin_cloudflare_cloudflare-bindings__hyperdrive_config_delete",
      "mcp__plugin_cloudflare_cloudflare-bindings__d1_database_create",
      "mcp__plugin_cloudflare_cloudflare-bindings__kv_namespace_create",
      "mcp__plugin_cloudflare_cloudflare-bindings__kv_namespace_update",
      "mcp__plugin_cloudflare_cloudflare-bindings__r2_bucket_create",
      "mcp__plugin_cloudflare_cloudflare-bindings__hyperdrive_config_edit",
      "mcp__plugin_github_github__merge_pull_request",
      "mcp__plugin_github_github__delete_file",
      "mcp__plugin_github_github__delete_project_item",
      "mcp__plugin_github_github__push_files"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "cloudflare@cloudflare": true,
    "grafana-cloud-mcp@grafana-ai-marketplace": true,
    "commit-commands@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "semgrep@claude-plugins-official": true,
    "session-report@claude-plugins-official": false,
    "sux@sux": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      },
      "autoUpdate": true
    },
    "grafana-ai-marketplace": {
      "source": {
        "source": "github",
        "repo": "grafana/ai-marketplace"
      },
      "autoUpdate": true
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      },
      "autoUpdate": true
    },
    "sux": {
      "source": {
        "source": "git",
        "url": "https://github.com/SuxOS/sux.git"
      },
      "autoUpdate": true
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "outputStyle": "Explanatory",
  "theme": "dark-daltonized",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "autoMode": {
    "allow": [
      "$defaults",
      "Any read-only or standard developer shell command (git, gh, npm/npx including wrangler, python3, node, grep/find/sed/awk/cat/ls), including setting non-secret configuration — except the network-egress and destructive/write subcommands (curl/wget/scp/tar, gh api writes / gh secret / gh auth / gh repo delete·edit·transfer, wrangler deploy/secret/delete) that are denied by name in permissions.deny; this line re-grants nothing that deny list restricts, and gh api writes it misses (implicit-POST field flags, glued --method forms) are UNENFORCED while the block-egress.py rail stays unregistered from pretooluse-bash.py (owner decision 2026-07-22, the same order that removed Bash(ssh *) from deny: the rail’s false-positive rate on routine interactive work outweighed its speed-bump value; re-arm via _RAIL_MODULES to restore both catches and the dormant fail-closed LAN-ssh carve-out)",
      "Read- and list-shaped MCP tool calls to the user's own connected servers (sux, cloudflare, grafana, scheduled-tasks, session management, browser automation, obsidian); destructive Cloudflare MCP tools (create/update/edit/delete for d1, kv, r2, hyperdrive) and destructive GitHub MCP tools (merge_pull_request, delete_file, delete_project_item, push_files) are Tier A and denied by exact tool name in permissions.deny — Claude Code's deny matches exact names, not patterns, so each destructive tool must be listed explicitly there; block-destructive-mcp.py's verb-pattern rail (#260) also covers these unconditionally, so the exact-name list is belt-and-suspenders, not the only gate",
      "Reading, editing, and writing files in the user's Code repos and .claude config; opening PRs; pushing branches; and inspecting Cloudflare Worker state via read-only wrangler subcommands (tail, deployments list, kv key get) — deploy, secret, and delete subcommands are Tier A, denied, and require human hands"
    ]
  },
  "disableClaudeAiConnectors": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/check-settings-drift.py" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/require-delegation-model.py" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/pretooluse-bash.py" }
        ]
      },
      {
        "matcher": "mcp__.*__.*",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/block-destructive-mcp.py" }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/block-web-egress.py" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/block-write-overwrite.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/audit-git-consequences.py" }
        ]
      }
    ]
  },
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true
}
