{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Bash(gh repo *)",
      "Bash(gh search *)",
      "Bash(gh api *)",
      "Bash(npx wrangler *)",
      "Bash(npm *)",
      "Bash(python3 *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(node *)",
      "WebFetch",
      "WebSearch",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(tar *)",
      "Bash(gh secret *)",
      "Bash(gh auth *)",
      "Bash(gh repo delete *)",
      "Bash(gh repo edit *)",
      "Bash(gh repo transfer *)",
      "Bash(gh api *)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "cloudflare@cloudflare": true,
    "grafana-cloud-mcp@grafana-ai-marketplace": true,
    "commit-commands@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "mcp-tunnels@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "project-artifact@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "sux@sux": true,
    "explanatory-output-style@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "github@claude-plugins-official": true,
    "semgrep@claude-plugins-official": true,
    "session-report@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      },
      "autoUpdate": false
    },
    "sux": {
      "source": {
        "source": "github",
        "repo": "SuxOS/sux"
      },
      "autoUpdate": false
    },
    "grafana-ai-marketplace": {
      "source": {
        "source": "github",
        "repo": "grafana/ai-marketplace"
      },
      "autoUpdate": false
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-daltonized",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "autoMode": {
    "allow": [
      "$defaults",
      "Any read-only or standard developer shell command (git, gh, npm/npx including wrangler, python3, node, grep/find/sed/awk/cat/ls), including setting non-secret configuration",
      "All MCP tool calls to the user's own connected servers (sux, cloudflare, grafana, scheduled-tasks, session management, browser automation, obsidian)",
      "Reading, editing, and writing files in the user's Code repos and .claude config; opening PRs; pushing branches; and setting the user's own Cloudflare Worker config/secrets via wrangler"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/require-delegation-model.py" }
        ]
      }
    ]
  }
}
