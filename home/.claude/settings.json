{
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "cloudflare@cloudflare": true,
    "grafana-cloud-mcp@grafana-ai-marketplace": true,
    "commit-commands@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "semgrep@claude-plugins-official": true,
    "session-report@claude-plugins-official": true,
    "sux@sux": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      },
      "autoUpdate": true
    },
    "grafana-ai-marketplace": {
      "source": {
        "source": "github",
        "repo": "grafana/ai-marketplace"
      },
      "autoUpdate": true
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      },
      "autoUpdate": true
    },
    "sux": {
      "source": {
        "source": "github",
        "url": "suxos/sux"
      },
      "autoUpdate": true
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "outputStyle": "Explanatory",
  "theme": "dark-daltonized",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "autoMode": {
    "allow": [
      "$defaults",
    ]
  },
  "disableClaudeAiConnectors": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/check-settings-drift.py" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/require-delegation-model.py" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/pretooluse-bash.py" }
        ]
      },
      {
        "matcher": "mcp__.*__.*",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/block-destructive-mcp.py" }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/block-web-egress.py" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/block-write-overwrite.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/audit-git-consequences.py" }
        ]
      }
    ]
  },
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true
}
